# ============================================================
#  .streamlit/secrets.toml 템플릿
#  ─────────────────────────────────────────────────────────
#  ⚠️  이 파일은 예시입니다. 실제 값을 채운 뒤
#      파일명을 "secrets.toml" 로 바꾸고
#      절대 GitHub에 올리지 마세요! (.gitignore 에 포함됨)
# ============================================================

# ── 관리자 페이지 비밀번호 ──────────────────────────────────
[admin]
password = "여기에_비밀번호_입력"

# ── Google Cloud 서비스 계정 (Sheets 연동 시 필요) ─────────
# GCP 콘솔 → IAM → 서비스 계정 → JSON 키 생성 후 값 복사
[gcp_service_account]
type                        = "service_account"
project_id                  = "your-project-id"
private_key_id              = "key-id-here"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\n...(줄바꿈은 \\n 으로)...\n-----END RSA PRIVATE KEY-----\n"
client_email                = "gilzabi@your-project.iam.gserviceaccount.com"
client_id                   = "123456789"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com"

# ── Google Sheets ID 및 탭 이름 ─────────────────────────────
# 스프레드시트 URL: https://docs.google.com/spreadsheets/d/[ID]/edit
[sheets]
timetable_id     = "스프레드시트_ID_여기에"
timetable_sheet  = "시간표"      # 탭 이름
teachers_sheet   = "선생님"      # 탭 이름
rooms_sheet      = "교실"        # 탭 이름
